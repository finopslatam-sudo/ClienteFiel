# ============================================
# CLIENTE FIEL — BACKEND ENV EXAMPLE
# Copiar como .env y completar valores reales
# NUNCA commitear .env al repositorio
# ============================================

# Entorno
ENVIRONMENT=development

# Base de datos
DATABASE_URL=postgresql://clientefiel:password@localhost:5432/clientefiel_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Seguridad JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — URL del frontend
FRONTEND_URL=http://localhost:3000

# ============================================
# WHATSAPP — META CLOUD API
# Cada cliente conecta SU PROPIO WhatsApp Business.
# Estas credenciales son de la app Meta de Cliente Fiel
# (para verificar webhooks y gestionar el flujo OAuth).
# Las credenciales del cliente (phone_number_id, access_token)
# se almacenan cifradas en la DB por tenant.
# ============================================
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_WEBHOOK_VERIFY_TOKEN=your-random-webhook-verify-token

# Clave de cifrado para tokens WhatsApp de clientes (AES-256)
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ============================================
# STRIPE
# ============================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BASIC_PRICE_ID=price_...
STRIPE_MEDIUM_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ============================================
# CELERY
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
