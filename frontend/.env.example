# ============================================
# CLIENTE FIEL — FRONTEND ENV EXAMPLE
# Copiar como .env.local para desarrollo
# NUNCA commitear .env.local al repositorio
# ============================================

# URL del backend (FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Meta App ID (solo para el flujo de conexión WhatsApp en el cliente)
# NO es el secret — solo el App ID público para el SDK JS de Meta
NEXT_PUBLIC_META_APP_ID=your-meta-app-id

# URL pública del sitio (para SEO, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=https://clientefiel.cl

# Stripe publishable key (pública, segura en cliente)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
